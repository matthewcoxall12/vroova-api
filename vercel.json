{
  "rewrites": [
    {
      "source": "/v1",
      "destination": "/api"
    },
    {
      "source": "/v1/:path*",
      "destination": "/api?path=:path*"
    },
    {
      "source": "/cron/:path*",
      "destination": "/api?path=cron/:path*"
    }
  ],
  "crons": [
    {
      "path": "/cron/refresh-vehicle-snapshots",
      "schedule": "0 5 * * *"
    }
  ]
}
